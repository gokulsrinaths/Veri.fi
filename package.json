{
  "name": "verifi",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm run --parallel dev",
    "dev:web": "pnpm --filter web dev",
    "dev:api": "pnpm --filter api dev",
    "build": "pnpm -r build",
    "build:web": "pnpm --filter web build",
    "build:api": "pnpm --filter api build",
    "build:contracts": "pnpm --filter contracts build",
    "test": "pnpm -r test",
    "test:contracts": "pnpm --filter contracts test",
    "test:api": "pnpm --filter api test",
    "db:generate": "pnpm --filter api exec prisma generate",
    "db:push": "pnpm --filter api exec prisma db push",
    "db:seed": "pnpm --filter api exec tsx prisma/seed.ts",
    "db:studio": "pnpm --filter api exec prisma studio",
    "contracts:compile": "pnpm --filter contracts compile",
    "contracts:deploy": "pnpm --filter contracts deploy"
  },
  "devDependencies": {
    "typescript": "5.3.3"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
